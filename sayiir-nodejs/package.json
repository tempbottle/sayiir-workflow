{
  "name": "sayiir",
  "version": "1.0.0",
  "description": "Durable workflow engine for Node.js — type-safe, fault-tolerant task orchestration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:native": "cd ../sayiir-node && cargo build --release && cp ../target/release/libsayiir_node.dylib ../sayiir-nodejs/native/sayiir-node.node || true",
    "build:ts": "tsc",
    "build": "pnpm run build:native && pnpm run build:ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ms": "^2.1.3",
    "@sayiir/flow-js": "workspace:*"
  },
  "optionalDependencies": {
    "@sayiir/node-darwin-arm64": "workspace:*",
    "@sayiir/node-darwin-x64": "workspace:*",
    "@sayiir/node-linux-arm64-gnu": "workspace:*",
    "@sayiir/node-linux-arm64-musl": "workspace:*",
    "@sayiir/node-linux-x64-gnu": "workspace:*",
    "@sayiir/node-linux-x64-musl": "workspace:*",
    "@sayiir/node-win32-arm64-msvc": "workspace:*",
    "@sayiir/node-win32-x64-msvc": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.3.1",
    "eslint": "^9.39.3",
    "testcontainers": "^11.14.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://docs.sayiir.dev",
  "bugs": {
    "url": "https://github.com/sayiir/sayiir/issues"
  },
  "author": {
    "name": "Sayiir",
    "url": "https://sayiir.dev"
  },
  "keywords": [
    "workflow",
    "workflow-engine",
    "durable",
    "durable-execution",
    "orchestration",
    "task",
    "task-queue",
    "job-queue",
    "saga",
    "dag",
    "state-machine",
    "distributed",
    "fault-tolerant",
    "checkpointing",
    "postgres",
    "typescript",
    "nodejs",
    "rust"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sayiir/sayiir.git",
    "directory": "sayiir-nodejs"
  }
}
