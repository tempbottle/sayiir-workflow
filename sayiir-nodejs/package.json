{
  "name": "sayiir",
  "version": "0.2.0",
  "description": "Durable workflow engine for Node.js — type-safe, fault-tolerant task orchestration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:native": "cd ../sayiir-node && cargo build --release && cp ../target/release/libsayiir_node.dylib ../sayiir-nodejs/native/sayiir-node.node || true",
    "build:ts": "tsc",
    "build": "pnpm run build:native && pnpm run build:ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ms": "^2.1.3"
  },
  "optionalDependencies": {
    "@sayiir/node-darwin-arm64": "workspace:*",
    "@sayiir/node-darwin-x64": "workspace:*",
    "@sayiir/node-linux-arm64-gnu": "workspace:*",
    "@sayiir/node-linux-x64-gnu": "workspace:*",
    "@sayiir/node-win32-x64-msvc": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testcontainers/postgresql": "^10.0.0",
    "@types/ms": "^2.0.0",
    "@types/node": "^25.2.3",
    "eslint": "^9.0.0",
    "testcontainers": "^10.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://docs.sayiir.dev",
  "bugs": {
    "url": "https://github.com/sayiir/sayiir/issues"
  },
  "author": "Sayiir",
  "keywords": [
    "workflow",
    "durable",
    "orchestration",
    "task",
    "typescript",
    "rust",
    "fault-tolerant",
    "checkpointing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sayiir/sayiir"
  }
}
