{
  "name": "sayiir",
  "version": "0.1.0-alpha.8",
  "description": "Durable workflow engine for Node.js — type-safe, fault-tolerant task orchestration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:native": "cd ../sayiir-node && cargo build --release && cp ../target/release/libsayiir_node.dylib ../sayiir-nodejs/native/sayiir-node.node || true",
    "build:ts": "tsc",
    "build": "pnpm run build:native && pnpm run build:ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ms": "^2.1.3"
  },
  "optionalDependencies": {
    "@sayiir/node-linux-x64-gnu": "0.1.0-alpha.8",
    "@sayiir/node-linux-arm64-gnu": "0.1.0-alpha.8",
    "@sayiir/node-darwin-x64": "0.1.0-alpha.8",
    "@sayiir/node-darwin-arm64": "0.1.0-alpha.8",
    "@sayiir/node-win32-x64-msvc": "0.1.0-alpha.8"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.0.0",
    "@types/ms": "^2.0.0",
    "@types/node": "^25.2.3",
    "testcontainers": "^10.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sayiir/sayiir"
  }
}