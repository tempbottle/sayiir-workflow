{
  "name": "sayiir-flow-js",
  "version": "0.4.0",
  "description": "Pure TypeScript workflow builder DSL for Sayiir — no native dependencies",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:ts": "tsc",
    "build": "pnpm run build:ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ms": "^2.1.3"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://docs.sayiir.dev",
  "bugs": {
    "url": "https://github.com/sayiir/sayiir/issues"
  },
  "author": "Sayiir",
  "keywords": [
    "workflow",
    "durable",
    "orchestration",
    "task",
    "typescript",
    "builder",
    "dsl"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sayiir/sayiir"
  }
}