---
// Standalone playground frame — rendered WITHOUT Starlight layout.
// Embedded via iframe in playground.astro for CSS isolation.
import { readFileSync } from "node:fs";
import { resolve } from "node:path";

const codapiUrl = import.meta.env.PUBLIC_CODAPI_URL || "http://localhost:1313";
const sayiirDts = readFileSync(resolve(process.cwd(), "../playground/sayiir.d.ts"), "utf-8");

// Playground example snippets — kept as standalone files for easy editing.
const examplesDir = resolve(process.cwd(), "../playground/examples");
const read = (path: string) => readFileSync(resolve(examplesDir, path), "utf-8");

const examples = {
  python: {
    hello: read("python/hello.py"),
    parallel: read("python/parallel.py"),
    retry: read("python/retry.py"),
    routing: read("python/routing.py"),
  },
  node: {
    hello: read("node/hello.js"),
    parallel: read("node/parallel.js"),
    retry: read("node/retry.js"),
    routing: read("node/routing.js"),
  },
};
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex">
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --accent: #6366f1;
      --accent-hover: #818cf8;
      --accent-low: #1a1a2e;
      --bg: #0f0f1a;
      --bg-surface: #181828;
      --text: #e2e8f0;
      --text-muted: #94a3b8;
      --border: #2e2e4a;
      --success: #22c55e;
      --error: #ef4444;
      --font-sans: system-ui, -apple-system, 'Segoe UI', sans-serif;
      --font-mono: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', ui-monospace, monospace;
    }

    html[data-theme="light"] {
      --accent: #4f46e5;
      --accent-hover: #6366f1;
      --accent-low: #e0e7ff;
      --bg: #ffffff;
      --bg-surface: #f8fafc;
      --text: #1e293b;
      --text-muted: #64748b;
      --border: #e2e8f0;
    }

    html, body {
      margin: 0;
      padding: 0;
      font-family: var(--font-sans);
      background: var(--bg);
      color: var(--text);
    }

    /* ── Toolbar ── */
    .toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-bottom: none;
      border-radius: 10px 10px 0 0;
      padding: 0.5rem 0.75rem;
      flex-shrink: 0;
    }

    .tabs { display: flex; gap: 0; }

    .tab {
      padding: 0.4rem 0.9rem;
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--text-muted);
      background: none;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: color 0.15s, background 0.15s;
      font-family: var(--font-sans);
    }

    .tab:hover { color: var(--text); background: var(--accent-low); }
    .tab.active { color: var(--accent); background: var(--accent-low); }

    .toolbar-actions { display: flex; align-items: center; gap: 0.5rem; }

    .file-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--text-muted);
      padding: 0.25rem 0.5rem;
      background: var(--bg);
      border-radius: 4px;
    }

    .btn {
      font-family: var(--font-sans);
      font-size: 0.8rem;
      font-weight: 500;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      padding: 0.45rem 1rem;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      transition: background 0.15s, transform 0.1s;
    }

    .btn:active { transform: scale(0.97); }

    .btn-run { background: var(--accent); color: #fff; }
    .btn-run:hover { background: var(--accent-hover); }
    .btn-run:disabled { opacity: 0.6; cursor: not-allowed; }

    .btn-reset {
      background: transparent;
      color: var(--text-muted);
      border: 1px solid var(--border);
    }
    .btn-reset:hover { color: var(--text); border-color: var(--text-muted); }

    .spinner {
      width: 14px; height: 14px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      display: inline-block;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Editor ── */
    .editor-wrapper {
      border-left: 1px solid var(--border);
      border-right: 1px solid var(--border);
      height: 300px;
      flex-shrink: 0;
      overflow: hidden;
    }

    #editor { width: 100%; height: 100%; }

    /* ── Output ── */
    .output-wrapper {
      border: 1px solid var(--border);
      border-radius: 0 0 10px 10px;
      overflow: hidden;
      flex-shrink: 0;
    }

    .output-header {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-muted);
      padding: 0.5rem 0.75rem;
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .output-status { font-family: var(--font-mono); font-size: 0.7rem; }
    .output-status.success { color: var(--success); }
    .output-status.error { color: var(--error); }

    .output-body {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      line-height: 1.6;
      padding: 0.75rem 1rem;
      background: var(--bg);
      min-height: 80px;
      max-height: 200px;
      overflow-y: auto;
      box-sizing: content-box;
      white-space: pre-wrap;
      word-break: break-word;
      color: var(--text-muted);
    }

    .output-body.has-content { color: var(--text); }
    .output-body.has-error { color: var(--error); }

    /* ── Examples ── */
    .examples { padding: 0.75rem 0; flex-shrink: 0; }
    .examples h2 {
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text-muted);
    }
    .example-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .chip {
      font-size: 0.78rem;
      font-family: var(--font-sans);
      padding: 0.35rem 0.8rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--bg-surface);
      color: var(--text-muted);
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s, background 0.15s;
    }
    .chip:hover, .chip.active {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--accent-low);
    }
  </style>
</head>
<body>
  <div id="frame-root">
    <div class="toolbar">
      <div class="tabs">
        <button class="tab active" data-lang="python">Python</button>
        <button class="tab" data-lang="node">Node.js</button>
      </div>
      <div class="toolbar-actions">
        <span class="file-label" id="file-label">main.py</span>
        <button class="btn btn-reset" id="reset-btn">Reset</button>
        <button class="btn btn-run" id="run-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
          Run
        </button>
      </div>
    </div>

    <div class="editor-wrapper">
      <div id="editor"></div>
    </div>

    <div class="output-wrapper">
      <div class="output-header">
        <span>Output</span>
        <span class="output-status" id="output-status"></span>
      </div>
      <div class="output-body" id="output">Click Run or press Ctrl+Enter</div>
    </div>

    <div class="examples">
      <h2>Examples</h2>
      <div class="example-chips">
        <button class="chip active" data-example="hello">Hello World</button>
        <button class="chip" data-example="parallel">Parallel Tasks</button>
        <button class="chip" data-example="retry">Retries</button>
        <button class="chip" data-example="routing">Routing</button>
      </div>
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs/loader.js"></script>
  <script is:inline define:vars={{ codapiUrl, sayiirDts, examples }}>
    var CODAPI_URL = codapiUrl + '/v1/exec';

    var LANGS = {
      python: { monaco: 'python', sandbox: 'sayiir-python', entry: 'main.py', label: 'main.py' },
      node:   { monaco: 'javascript', sandbox: 'sayiir-node', entry: 'main.js', label: 'main.js' },
    };

    var EXAMPLES = examples;

    var currentLang = 'python';
    var currentExample = 'hello';
    var editor = null;
    var isRunning = false;

    // ── Theme sync from parent (Starlight) ──
    window.addEventListener('message', function(e) {
      if (e.origin !== window.location.origin) return;
      if (e.data && e.data.type === 'theme') {
        var theme = e.data.theme;
        document.documentElement.setAttribute('data-theme', theme);
        if (editor && typeof monaco !== 'undefined') {
          monaco.editor.setTheme(theme === 'light' ? 'sayiir-light' : 'sayiir-dark');
        }
      }
    });

    // ── Monaco ──
    require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs' } });

    require(['vs/editor/editor.main'], function () {
      // JS type declarations
      monaco.languages.typescript.javascriptDefaults.setDiagnosticsOptions({
        noSemanticValidation: false,
        noSyntaxValidation: false,
      });
      monaco.languages.typescript.javascriptDefaults.setCompilerOptions({
        target: monaco.languages.typescript.ScriptTarget.ES2020,
        allowNonTsExtensions: true,
        moduleResolution: monaco.languages.typescript.ModuleResolutionKind.NodeJs,
        module: monaco.languages.typescript.ModuleKind.CommonJS,
        checkJs: true,
        allowJs: true,
        strict: false,
      });
      monaco.languages.typescript.javascriptDefaults.addExtraLib(sayiirDts, 'sayiir.d.ts');

      // Themes
      monaco.editor.defineTheme('sayiir-dark', {
        base: 'vs-dark', inherit: true,
        rules: [
          { token: 'comment', foreground: '6272a4', fontStyle: 'italic' },
          { token: 'keyword', foreground: 'c792ea' },
          { token: 'string', foreground: 'a5d6a7' },
          { token: 'number', foreground: 'f78c6c' },
          { token: 'type', foreground: '82aaff' },
          { token: 'function', foreground: '82aaff' },
        ],
        colors: {
          'editor.background': '#1e1e2e',
          'editor.foreground': '#e2e8f0',
          'editor.lineHighlightBackground': '#2a2a3e',
          'editor.selectionBackground': '#3e3e5e',
          'editorCursor.foreground': '#6366f1',
          'editorLineNumber.foreground': '#4a4a6a',
          'editorLineNumber.activeForeground': '#818cf8',
          'editorWidget.background': '#181828',
          'editorWidget.border': '#2e2e4a',
          'editorSuggestWidget.background': '#181828',
          'editorSuggestWidget.border': '#2e2e4a',
          'editorSuggestWidget.selectedBackground': '#2a2a3e',
        },
      });

      monaco.editor.defineTheme('sayiir-light', {
        base: 'vs', inherit: true,
        rules: [
          { token: 'comment', foreground: '6b7280', fontStyle: 'italic' },
          { token: 'keyword', foreground: '7c3aed' },
          { token: 'string', foreground: '16a34a' },
          { token: 'number', foreground: 'ea580c' },
          { token: 'type', foreground: '4f46e5' },
          { token: 'function', foreground: '4f46e5' },
        ],
        colors: {
          'editor.background': '#ffffff',
          'editor.foreground': '#1e293b',
          'editor.lineHighlightBackground': '#f1f5f9',
          'editor.selectionBackground': '#e0e7ff',
          'editorCursor.foreground': '#4f46e5',
          'editorLineNumber.foreground': '#cbd5e1',
          'editorLineNumber.activeForeground': '#4f46e5',
          'editorWidget.background': '#ffffff',
          'editorWidget.border': '#e2e8f0',
          'editorSuggestWidget.background': '#ffffff',
          'editorSuggestWidget.border': '#e2e8f0',
          'editorSuggestWidget.selectedBackground': '#f1f5f9',
        },
      });

      // Detect initial theme from parent
      var initialTheme = 'sayiir-dark';
      try {
        var parentTheme = window.parent.document.documentElement.dataset.theme;
        if (parentTheme === 'light' || window.parent.document.documentElement.classList.contains('sl-theme-light')) {
          initialTheme = 'sayiir-light';
          document.documentElement.setAttribute('data-theme', 'light');
        }
      } catch (e) { /* cross-origin, default to dark */ }

      editor = monaco.editor.create(document.getElementById('editor'), {
        value: EXAMPLES.python.hello,
        language: 'python',
        theme: initialTheme,
        fontFamily: "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace",
        fontSize: 12.5,
        lineHeight: 20,
        minimap: { enabled: false },
        scrollBeyondLastLine: false,
        padding: { top: 12, bottom: 12 },
        renderLineHighlight: 'line',
        automaticLayout: true,
        tabSize: 4,
        insertSpaces: true,
        wordWrap: 'on',
        suggestOnTriggerCharacters: true,
        quickSuggestions: true,
        parameterHints: { enabled: true },
        bracketPairColorization: { enabled: true },
        smoothScrolling: true,
        cursorBlinking: 'smooth',
        cursorSmoothCaretAnimation: 'on',
        scrollbar: { verticalScrollbarSize: 8, horizontalScrollbarSize: 8, useShadows: false },
      });

      editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyCode.Enter, handleRun);

      // Register completion/hover/signature providers
      registerPythonProviders(monaco);
      registerJSProviders(monaco);
    });

    function registerPythonProviders(monaco) {
      var CK = monaco.languages.CompletionItemKind;

      var SAYIIR_PY = [
        { label: 'task', kind: CK.Function, detail: 'decorator', doc: '@task — mark a function as a workflow task' },
        { label: 'Flow', kind: CK.Class, detail: 'class', doc: 'Flow(name) — build a workflow' },
        { label: 'run_workflow', kind: CK.Function, detail: 'function', doc: 'run_workflow(workflow, input) -> Any' },
        { label: 'run_durable_workflow', kind: CK.Function, detail: 'function', doc: 'run_durable_workflow(workflow, instance_id, input, backend, conflict_policy=None) -> WorkflowStatus' },
        { label: 'resume_workflow', kind: CK.Function, detail: 'function', doc: 'resume_workflow(workflow, instance_id, backend) -> WorkflowStatus' },
        { label: 'InMemoryBackend', kind: CK.Class, detail: 'class', doc: 'InMemoryBackend() — in-memory persistence' },
        { label: 'PostgresBackend', kind: CK.Class, detail: 'class', doc: 'PostgresBackend(url) — PostgreSQL persistence' },
        { label: 'RetryPolicy', kind: CK.Class, detail: 'class', doc: 'RetryPolicy(max_retries, initial_delay_secs=1.0, backoff_multiplier=2.0)' },
        { label: 'LoopResult', kind: CK.Class, detail: 'class', doc: 'LoopResult.again(value) / LoopResult.done(value) — control loop iteration' },
        { label: 'OnMax', kind: CK.Enum, detail: 'enum', doc: 'OnMax.FAIL / OnMax.EXIT_WITH_LAST — max-iterations policy' },
        { label: 'send_signal', kind: CK.Function, detail: 'function', doc: 'send_signal(instance_id, signal_name, payload, backend)' },
        { label: 'cancel_workflow', kind: CK.Function, detail: 'function', doc: 'cancel_workflow(instance_id, backend, reason=None, cancelled_by=None)' },
        { label: 'pause_workflow', kind: CK.Function, detail: 'function', doc: 'pause_workflow(instance_id, backend, reason=None, paused_by=None)' },
        { label: 'unpause_workflow', kind: CK.Function, detail: 'function', doc: 'unpause_workflow(instance_id, backend)' },
        { label: 'Worker', kind: CK.Class, detail: 'class', doc: 'Worker(worker_id, backend, workflows, opts=None) — distributed executor' },
        { label: 'WorkflowClient', kind: CK.Class, detail: 'class', doc: 'WorkflowClient(backend, conflict_policy=None) — submit & control instances' },
        { label: 'get_task_context', kind: CK.Function, detail: 'function', doc: 'get_task_context() -> TaskExecutionContext' },
      ];

      var FLOW_METHODS_PY = [
        { label: 'then', kind: CK.Method, detail: 'Flow', doc: '.then(task_fn)', insert: 'then(${1:task_fn})' },
        { label: 'fork', kind: CK.Method, detail: 'ForkBuilder', doc: '.fork()', insert: 'fork()' },
        { label: 'route', kind: CK.Method, detail: 'BranchBuilder', doc: '.route(key_fn, keys=[...])', insert: 'route(${1:key_fn}, keys=[${2:"a", "b"}])' },
        { label: 'delay', kind: CK.Method, detail: 'Flow', doc: '.delay(name, duration)', insert: 'delay("${1:name}", "${2:30s}")' },
        { label: 'wait_for_signal', kind: CK.Method, detail: 'Flow', doc: '.wait_for_signal(signal_name)', insert: 'wait_for_signal("${1:signal_name}")' },
        { label: 'loop', kind: CK.Method, detail: 'Flow', doc: '.loop(task_fn, max_iterations=10, on_max="fail")', insert: 'loop(${1:task_fn}, max_iterations=${2:10})' },
        { label: 'then_flow', kind: CK.Method, detail: 'Flow', doc: '.then_flow(child_workflow)', insert: 'then_flow(${1:child_workflow})' },
        { label: 'build', kind: CK.Method, detail: 'Workflow', doc: '.build()', insert: 'build()' },
        { label: 'branch', kind: CK.Method, detail: 'ForkBuilder', doc: '.branch(task_fn)', insert: 'branch(${1})' },
        { label: 'join', kind: CK.Method, detail: 'Flow', doc: '.join(task_fn)', insert: 'join(${1:task_fn})' },
        { label: 'done', kind: CK.Method, detail: 'Flow', doc: '.done()', insert: 'done()' },
        { label: 'default_branch', kind: CK.Method, detail: 'BranchBuilder', doc: '.default_branch(task_fn)', insert: 'default_branch(${1:task_fn})' },
      ];

      function mkCompletion(item, range) {
        return {
          label: item.label, kind: item.kind, detail: item.detail,
          documentation: { value: item.doc },
          insertText: item.insert || item.label,
          insertTextRules: item.insert ? monaco.languages.CompletionItemInsertTextRule.InsertAsSnippet : undefined,
          range: range,
        };
      }

      monaco.languages.registerCompletionItemProvider('python', {
        triggerCharacters: ['.', '(', ' '],
        provideCompletionItems: function(model, position) {
          var textUntilPos = model.getValueInRange({
            startLineNumber: position.lineNumber, startColumn: 1,
            endLineNumber: position.lineNumber, endColumn: position.column,
          });
          var word = model.getWordUntilPosition(position);
          var range = {
            startLineNumber: position.lineNumber, endLineNumber: position.lineNumber,
            startColumn: word.startColumn, endColumn: word.endColumn,
          };
          if (textUntilPos.match(/\.\s*[a-z_]*$/)) {
            return { suggestions: FLOW_METHODS_PY.map(function(i) { return mkCompletion(i, range); }) };
          }
          return { suggestions: SAYIIR_PY.map(function(i) { return mkCompletion(i, range); }) };
        },
      });

      // Hover
      var PY_HOVER = {
        task: '```python\n@task(name=None, timeout=None, retries=None, tags=None, description=None, priority=None)\n```\nMark a function as a workflow task. Priority: 1 (highest) to 5 (lowest).',
        Flow: '```python\nFlow(name: str, *, metadata=None)\n```\nBuild a workflow. Methods: `.then()` `.fork()` `.route()` `.delay()` `.wait_for_signal()` `.loop()` `.then_flow()` `.build()`',
        run_workflow: '```python\nrun_workflow(workflow, input, *, instance_id=None, backend=None, conflict_policy=None) -> Any\n```\nRun a workflow and return the result.',
        run_durable_workflow: '```python\nrun_durable_workflow(workflow, instance_id, input, backend, conflict_policy=None) -> WorkflowStatus\n```\nRun with durable checkpointing.',
        resume_workflow: '```python\nresume_workflow(workflow, instance_id, backend) -> WorkflowStatus\n```\nResume a workflow from its last checkpoint.',
        send_signal: '```python\nsend_signal(instance_id, signal_name, payload, backend)\n```\nSend a signal to a waiting workflow.',
        cancel_workflow: '```python\ncancel_workflow(instance_id, backend, reason=None, cancelled_by=None)\n```\nCancel a running durable workflow.',
        InMemoryBackend: '```python\nInMemoryBackend()\n```\nIn-memory persistence (non-durable).',
        PostgresBackend: '```python\nPostgresBackend(url: str)\n```\nPostgreSQL persistence for production.',
        LoopResult: '```python\nLoopResult.again(value)  # continue loop\\nLoopResult.done(value)   # exit loop\n```\nControl loop iteration flow.',
        Worker: '```python\nWorker(worker_id, backend, workflows, opts=None)\n```\nDistributed workflow executor. Call `.start()` to begin polling.',
        WorkflowClient: '```python\nWorkflowClient(backend, conflict_policy=None)\n```\nSubmit and control workflow instances without executing tasks.',
      };

      monaco.languages.registerHoverProvider('python', {
        provideHover: function(model, position) {
          var word = model.getWordAtPosition(position);
          if (!word) return null;
          var doc = PY_HOVER[word.word];
          if (!doc) return null;
          return {
            range: new monaco.Range(position.lineNumber, word.startColumn, position.lineNumber, word.endColumn),
            contents: [{ value: doc }],
          };
        },
      });

      // Signature help
      var PY_SIGS = {
        Flow: { label: 'Flow(name: str, *, metadata=None)', params: [{ label: 'name: str', doc: 'Workflow name' }, { label: 'metadata=None', doc: 'Optional workflow-level metadata dict' }] },
        run_workflow: {
          label: 'run_workflow(workflow, input, *, instance_id=None, backend=None, conflict_policy=None)',
          params: [
            { label: 'workflow', doc: 'Compiled Workflow' },
            { label: 'input', doc: 'Input for first task' },
            { label: 'instance_id=None', doc: 'Optional instance ID (enables durability)' },
            { label: 'backend=None', doc: 'Optional backend (required with instance_id)' },
            { label: 'conflict_policy=None', doc: '"fail" | "use_existing" | "terminate_existing"' },
          ],
        },
        task: {
          label: '@task(name=None, timeout=None, retries=None, tags=None, description=None, priority=None)',
          params: [
            { label: 'name=None', doc: 'Custom task ID' },
            { label: 'timeout=None', doc: 'Max execution time: "30s", "5m"' },
            { label: 'retries=None', doc: 'Retry count or RetryPolicy' },
            { label: 'tags=None', doc: 'Metadata tags' },
            { label: 'description=None', doc: 'Human-readable description' },
            { label: 'priority=None', doc: 'Task priority 1 (highest) to 5 (lowest)' },
          ],
        },
      };

      monaco.languages.registerSignatureHelpProvider('python', {
        signatureHelpTriggerCharacters: ['(', ','],
        provideSignatureHelp: function(model, position) {
          var text = model.getValueInRange({
            startLineNumber: 1, startColumn: 1,
            endLineNumber: position.lineNumber, endColumn: position.column,
          });
          var funcName = null;
          var depth = 0;
          for (var i = text.length - 1; i >= 0; i--) {
            if (text[i] === ')') depth++;
            else if (text[i] === '(') {
              if (depth === 0) {
                var m = text.slice(0, i).match(/(\w+)\s*$/);
                if (m) funcName = m[1];
                break;
              }
              depth--;
            }
          }
          if (!funcName || !PY_SIGS[funcName]) return null;
          var sig = PY_SIGS[funcName];
          var insideParen = text.slice(text.lastIndexOf('(') + 1);
          var activeParam = 0;
          var d = 0;
          for (var j = 0; j < insideParen.length; j++) {
            if (insideParen[j] === '(' || insideParen[j] === '[') d++;
            else if (insideParen[j] === ')' || insideParen[j] === ']') d--;
            else if (insideParen[j] === ',' && d === 0) activeParam++;
          }
          return {
            value: {
              signatures: [{
                label: sig.label,
                parameters: sig.params.map(function(p) { return { label: p.label, documentation: { value: p.doc } }; }),
              }],
              activeSignature: 0,
              activeParameter: activeParam,
            },
            dispose: function() {},
          };
        },
      });
    }

    function registerJSProviders(monaco) {
      var CK = monaco.languages.CompletionItemKind;
      var SAYIIR_JS = [
        { label: 'task', kind: CK.Function, detail: 'function', doc: 'task(name, fn, opts?) — define a named task' },
        { label: 'flow', kind: CK.Function, detail: 'function', doc: 'flow(name, opts?) — build a workflow' },
        { label: 'branch', kind: CK.Function, detail: 'function', doc: 'branch(name, taskFn) — create a fork branch' },
        { label: 'runWorkflow', kind: CK.Function, detail: 'function', doc: 'runWorkflow(workflow, input, opts?) -> Promise<any>' },
        { label: 'runWorkflowSync', kind: CK.Function, detail: 'function', doc: 'runWorkflowSync(workflow, input) -> any' },
        { label: 'runDurableWorkflow', kind: CK.Function, detail: 'function', doc: 'runDurableWorkflow(workflow, instanceId, input, backend, conflictPolicy?)' },
        { label: 'resumeWorkflow', kind: CK.Function, detail: 'function', doc: 'resumeWorkflow(workflow, instanceId, backend)' },
        { label: 'sendSignal', kind: CK.Function, detail: 'function', doc: 'sendSignal(instanceId, signalName, payload, backend)' },
        { label: 'cancelWorkflow', kind: CK.Function, detail: 'function', doc: 'cancelWorkflow(instanceId, backend, opts?)' },
        { label: 'pauseWorkflow', kind: CK.Function, detail: 'function', doc: 'pauseWorkflow(instanceId, backend, opts?)' },
        { label: 'unpauseWorkflow', kind: CK.Function, detail: 'function', doc: 'unpauseWorkflow(instanceId, backend)' },
        { label: 'LoopResult', kind: CK.Class, detail: 'object', doc: 'LoopResult.again(value) / LoopResult.done(value)' },
        { label: 'InMemoryBackend', kind: CK.Class, detail: 'class', doc: 'new InMemoryBackend()' },
        { label: 'PostgresBackend', kind: CK.Class, detail: 'class', doc: 'PostgresBackend.connect(url)' },
        { label: 'Worker', kind: CK.Class, detail: 'class', doc: 'new Worker(workerId, backend, workflows, opts?)' },
        { label: 'WorkflowClient', kind: CK.Class, detail: 'class', doc: 'new WorkflowClient(backend, opts?)' },
        { label: 'getTaskContext', kind: CK.Function, detail: 'function', doc: 'getTaskContext() -> TaskExecutionContext | null' },
      ];
      var FLOW_METHODS_JS = [
        { label: 'then', kind: CK.Method, detail: 'Flow', insert: 'then(${1:taskFn})' },
        { label: 'fork', kind: CK.Method, detail: 'ForkBuilder', insert: 'fork([${1}])' },
        { label: 'route', kind: CK.Method, detail: 'RouteBuilder', insert: 'route(${1:keyFn}, [${2:"a", "b"}])' },
        { label: 'delay', kind: CK.Method, detail: 'Flow', insert: 'delay("${1:id}", "${2:30s}")' },
        { label: 'waitForSignal', kind: CK.Method, detail: 'Flow', insert: 'waitForSignal("${1:id}", "${2:signal_name}", { timeout: "${3:1h}" })' },
        { label: 'loop', kind: CK.Method, detail: 'Flow', insert: 'loop(${1:taskFn}, { maxIterations: ${2:10} })' },
        { label: 'thenFlow', kind: CK.Method, detail: 'Flow', insert: 'thenFlow(${1:childWorkflow})' },
        { label: 'build', kind: CK.Method, detail: 'Workflow', insert: 'build()' },
        { label: 'join', kind: CK.Method, detail: 'Flow', insert: 'join("${1:id}", ${2:fn})' },
        { label: 'branch', kind: CK.Method, detail: 'RouteBuilder', insert: 'branch("${1:key}", ${2:taskFn})' },
        { label: 'defaultBranch', kind: CK.Method, detail: 'RouteBuilder', insert: 'defaultBranch(${1:taskFn})' },
        { label: 'done', kind: CK.Method, detail: 'Flow', insert: 'done()' },
      ];

      monaco.languages.registerCompletionItemProvider('javascript', {
        triggerCharacters: ['.', ' '],
        provideCompletionItems: function(model, position) {
          var textUntilPos = model.getValueInRange({
            startLineNumber: position.lineNumber, startColumn: 1,
            endLineNumber: position.lineNumber, endColumn: position.column,
          });
          var word = model.getWordUntilPosition(position);
          var range = {
            startLineNumber: position.lineNumber, endLineNumber: position.lineNumber,
            startColumn: word.startColumn, endColumn: word.endColumn,
          };
          if (textUntilPos.match(/\.\s*[a-zA-Z]*$/)) {
            return {
              suggestions: FLOW_METHODS_JS.map(function(i) {
                return {
                  label: i.label, kind: i.kind, detail: i.detail,
                  insertText: i.insert || i.label,
                  insertTextRules: i.insert ? monaco.languages.CompletionItemInsertTextRule.InsertAsSnippet : undefined,
                  range: range,
                };
              }),
            };
          }
          return {
            suggestions: SAYIIR_JS.map(function(i) {
              return {
                label: i.label, kind: i.kind, detail: i.detail,
                documentation: i.doc ? { value: i.doc } : undefined,
                insertText: i.label, range: range,
              };
            }),
          };
        },
      });
    }

    // ── Tab switching ──
    document.querySelectorAll('.tab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        var lang = tab.dataset.lang;
        if (lang === currentLang) return;
        document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        currentLang = lang;
        document.getElementById('file-label').textContent = LANGS[lang].label;
        var code = EXAMPLES[lang][currentExample] || EXAMPLES[lang].hello;
        monaco.editor.setModelLanguage(editor.getModel(), LANGS[lang].monaco);
        editor.setValue(code);
        clearOutput();
      });
    });

    // ── Example chips ──
    document.querySelectorAll('.chip').forEach(function(chip) {
      chip.addEventListener('click', function() {
        var example = chip.dataset.example;
        document.querySelectorAll('.chip').forEach(function(c) { c.classList.remove('active'); });
        chip.classList.add('active');
        currentExample = example;
        var code = EXAMPLES[currentLang][example];
        if (code) editor.setValue(code);
        clearOutput();
      });
    });

    // ── Run ──
    async function handleRun() {
      if (isRunning || !editor) return;
      isRunning = true;
      var btn = document.getElementById('run-btn');
      var playIcon = btn.querySelector('svg');
      if (playIcon) playIcon.style.display = 'none';
      var spinnerEl = document.createElement('span');
      spinnerEl.className = 'spinner';
      btn.insertBefore(spinnerEl, btn.firstChild);
      btn.disabled = true;
      var output = document.getElementById('output');
      var status = document.getElementById('output-status');
      output.textContent = '';
      output.className = 'output-body';
      status.textContent = '';
      status.className = 'output-status';
      var cfg = LANGS[currentLang];
      var code = editor.getValue();
      // Detect ESM syntax for Node.js → use run-esm command + .mjs entry
      var isEsm = currentLang === 'node' && /^\s*(import |export )/m.test(code);
      var entry = isEsm ? 'main.mjs' : cfg.entry;
      var command = isEsm ? 'run-esm' : 'run';
      var files = {};
      files[entry] = code;
      try {
        var start = performance.now();
        var res = await fetch(CODAPI_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sandbox: cfg.sandbox, command: command, files: files }),
        });
        var data = await res.json();
        var elapsed = Math.round(performance.now() - start);
        if (data.ok) {
          output.textContent = data.stdout || '(no output)';
          output.classList.add('has-content');
          status.textContent = '\u2713 ' + elapsed + 'ms';
          status.classList.add('success');
        } else {
          output.textContent = data.stderr || data.stdout || 'Unknown error';
          output.classList.add('has-error');
          status.textContent = '\u2717 failed';
          status.classList.add('error');
        }
      } catch (err) {
        output.textContent = 'Connection error: ' + err.message;
        output.classList.add('has-error');
        status.textContent = '\u2717 error';
        status.classList.add('error');
      } finally {
        var spinner = btn.querySelector('.spinner');
        if (spinner) spinner.remove();
        if (playIcon) playIcon.style.display = '';
        btn.disabled = false;
        isRunning = false;
      }
    }

    document.getElementById('run-btn').addEventListener('click', handleRun);
    document.getElementById('reset-btn').addEventListener('click', function() {
      var code = EXAMPLES[currentLang][currentExample];
      if (code && editor) editor.setValue(code);
      clearOutput();
    });

    // Global Ctrl+Enter / Cmd+Enter fallback (works even when editor doesn't have focus)
    document.addEventListener('keydown', function(e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
        e.preventDefault();
        handleRun();
      }
    });

    function clearOutput() {
      document.getElementById('output').textContent = 'Click Run or press Ctrl+Enter';
      document.getElementById('output').className = 'output-body';
      document.getElementById('output-status').textContent = '';
      document.getElementById('output-status').className = 'output-status';
    }
  </script>
</body>
</html>
