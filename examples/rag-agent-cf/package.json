{
  "name": "rag-agent-cf",
  "private": true,
  "version": "0.0.0",
  "description": "Durable RAG assistant on Cloudflare Workers, powered by Sayiir + Workers AI + Vectorize + R2 + D1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply rag-agent --local",
    "db:migrate:remote": "wrangler d1 migrations apply rag-agent --remote",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sayiir/cloudflare": "workspace:*",
    "node-html-parser": "^7.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
