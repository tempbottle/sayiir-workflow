{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-agent-cf",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],

  // Sayiir checkpoints + example drafts/reports share this D1 instance.
  // Run `wrangler d1 create sayiir-agent` and paste the id below.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sayiir-agent",
      "database_id": "REPLACE_WITH_YOUR_D1_ID",
      "migrations_dir": "migrations"
    }
  ],

  // Workers AI — used by the refineAnswer task.
  "ai": {
    "binding": "AI"
  },

  // Cron sweeps for stuck/expired workflow instances.
  "triggers": {
    "crons": ["* * * * *"]
  },

  "observability": {
    "enabled": true
  }
}
